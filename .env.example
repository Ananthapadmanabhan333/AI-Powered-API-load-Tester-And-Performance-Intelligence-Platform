# AI Performance OS Environment Variables

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-your-anthropic-key-here

# Database
DATABASE_URL=postgresql://aegis:aegis_pass@localhost:5432/aegis
REDIS_URL=redis://localhost:6379/0

# Observability
PROMETHEUS_URL=http://localhost:9090
TEMPO_URL=http://localhost:3200
LOKI_URL=http://localhost:3100
GRAFANA_URL=http://localhost:3001

# Kafka Streaming
KAFKA_BROKER=localhost:9092

# K8s Config
KUBECONFIG_PATH=~/.kube/config
CHAOS_MESH_NAMESPACE=chaos-mesh

# Security
JWT_SECRET=super_secure_jwt_secret_for_enterprise_auth
ADMIN_EMAIL=admin@aegis-os.dev
